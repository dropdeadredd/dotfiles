{
  "editor.codeLens": false,
  "editor.minimap.maxColumn": 75,
  "editor.minimap.side": "left",
  "editor.minimap.size": "fill",
  "editor.minimap.scale": 2,
  "workbench.iconTheme": "icons",
  "workbench.productIconTheme": "el-vsc-v1-icons",
  "terminal.integrated.fontFamily": "monoLisa",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.lineHeight": 1,
  "terminal.integrated.letterSpacing": 0,
  "editor.fontFamily": "NotoSansM Nerd Font",
  "editor.fontSize": 14,
  "editor.lineHeight": 0,
  "editor.letterSpacing": 1,
  "editor.fontWeight": "normal",
  "editor.fontLigatures": true,
  "editor.fontVariations": false,
  "editor.cursorBlinking": "expand",
  "editor.cursorSmoothCaretAnimation": "explicit",
  "editor.cursorStyle": "line",
  "editor.cursorWidth": 3,
  "editor.cursorSurroundingLines": 2,
  "editor.cursorSurroundingLinesStyle": "all",
  "editor.hideCursorInOverviewRuler": true,
  "editor.find.cursorMoveOnType": true,
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.autoIndent": "advanced",
  "editor.bracketPairColorization.enabled": true,
  "editor.copyWithSyntaxHighlighting": true,
  "editor.detectIndentation": true,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.formatOnSaveMode": "modificationsIfAvailable",
  "workbench.hover.delay": 500,
  "files.autoSaveDelay": 1000,
  "files.autoSave": "afterDelay",
  "files.insertFinalNewline": false,
  "files.trimFinalNewlines": true,
  "remote.SSH.configFile": "~/.ssh/config",
  "remote.SSH.localServerDownload": "auto",
  "remote.SSH.remotePlatform": {
    "aws.ec2": "linux",
    "doc": "linux"
  },
  "powermode.presets": "exploding-rift",
  "powermode.combo.counterEnabled": "hide",
  "powermode.combo.timerEnabled": "hide",
  "powermode.shake.enabled": false,
  "powermode.shake.intensity": 0,
  "powermode.explosions.enabled": true,
  "powermode.explosions.size": 6,
  "powermode.explosions.explosionOrder": "sequential",
  "powermode.explosions.duration": 1000,
  "terminal.integrated.customGlyphs": true,
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.rightClickBehavior": "copyPaste",
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.profiles.linux": {
    "bash": {
      "path": "/usr/bin/flatpak-spawn",
      "args": ["--host", "--env=TERM=xterm-256color", "bash"]
    }
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
    "editor.wordWrap": "on",
  "editor.autoClosingDelete": "always",
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "off",
    "strings": "on"
  },
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "material-icon-theme.showWelcomeMessage": false,
  
  "editor.codeActionsOnSave": {
  },
  "redhat.telemetry.enabled": false,
  "workbench.colorTheme": "Themer My Color Set Dark",
  "editor.renderLineHighlight": "all",
  "editor.semanticHighlighting.enabled": false,
  "fonted.font": "Pragmata Pro Mono"
}
